{
  "permissions": {
    "allow": [
      "Bash(cd frontend && npm run lint)",
      "Bash(cd frontend && npm run build)",
      "Bash(cd frontend && npx tsc --noEmit)",
      "Bash(cd frontend && npx tsx voice-tests/runner.ts:*)",
      "Bash(cd backend && ruff check:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout -b:*)",
      "Bash(git push origin:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/guard.sh\""
          }
        ]
      }
    ]
  }
}
