<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSCameraUsageDescription</key>
	<string>Looper uses the camera to scan paper scorecards and read in your scores.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Looper uses the microphone so you can set up rounds and enter scores by voice.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Looper uses your location for caddie yardages and to find courses near you.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Looper can import a photo of your scorecard from your library to read in your scores.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Looper can save scorecard photos to your library.</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!--
	  WKAppBoundDomains enables "App-Bound" WKWebView mode for these domains.
	  iOS 14+ blocks third-party cookies for cross-origin requests in WKWebView
	  (Intelligent Tracking Prevention). App-Bound domains are treated as
	  first-party: their cookies are stored in the shared WKHTTPCookieStore and
	  are visible to the webview, which is required for Clerk's session cookie
	  (set by clerk.looperapp.org) to survive across page navigations inside the
	  same WKWebView session. Combined with CapacitorCookies.enabled=true and
	  standardBrowser=false on ClerkProvider, this forms the three-layer fix for
	  Clerk session persistence in the Capacitor WKWebView.
	-->
	<key>WKAppBoundDomains</key>
	<array>
		<string>clerk.looperapp.org</string>
		<string>looperapp.org</string>
	</array>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>Looper</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
</dict>
</plist>
