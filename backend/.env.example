# Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-xxx

# Model to use for voice parsing (set to Opus 4.6 model id)
ANTHROPIC_MODEL=claude-opus-4-20250514

# Postgres connection (Supabase or local). Required for persistent caddie sessions + memory.
# Use the asyncpg driver, e.g. postgresql+asyncpg://user:pass@host:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/scorecard

# Clerk JWT verification (optional in dev). When set, the backend verifies the
# Authorization: Bearer <token> header against Clerk's JWKS and binds requests to a user_id.
# Find this at https://dashboard.clerk.com → API Keys → JWKS endpoint.
CLERK_JWKS_URL=
CLERK_ISSUER=

# OpenAI Realtime — used by the conversational voice caddie (PR #2).
# Backend uses this key to mint short-lived (60s) ephemeral session tokens that the
# browser uses to connect to OpenAI over WebRTC. The full key never leaves the server.
OPENAI_API_KEY=sk-xxx
# Realtime model. Default: gpt-realtime. Override to gpt-4o-mini-realtime-preview to save cost.
OPENAI_REALTIME_MODEL=gpt-realtime
# Default voice when a personality doesn't pin one. Choices: alloy, ash, ballad, coral,
# echo, fable, onyx, nova, sage, shimmer, verse.
OPENAI_REALTIME_DEFAULT_VOICE=sage

# Deepgram — used for one-shot speech-to-text on voice round setup + score entry (PR #3).
# Free tier ($200 credit) is plenty for development. Model defaults to nova-3.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
