# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore all variants, keep examples
.env
.env.*
!.env.example
!.env.*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.Python
*.egg-info/
dist/

# Backend data (local storage — runtime caches, never checked in). Ignore
# contents, not the directory itself, so specific checked-in files below can
# be re-included (git can't un-ignore a file whose parent dir is excluded).
backend/data/*
# Exception: checked-in config data (specs/teetime-s0-plan.md) — the private-
# club exclusion list is source, not a runtime cache; loader fails loudly if
# it's missing, so it must ship with the repo.
!backend/data/private_clubs.json
# Exception: checked-in curated foreUP capability seed (specs/teetime-s1-foreup-plan.md)
# — fail-loud config, not a runtime cache; must ship with the repo.
!backend/data/foreup_ny_seed.json
# backend/data/foreup_availability_cache.json and foreup_validated.json stay
# ignored (already covered by backend/data/* above) — runtime-only.
# Exception: checked-in generalized multi-platform capability seed
# (specs/teetime-availability-everywhere-plan.md §2a) — same fail-loud
# config reasoning as foreup_ny_seed.json above; must ship with the repo.
!backend/data/booking_capabilities_seed.json
# backend/data/booking_capabilities_validated.json stays ignored (already
# covered by backend/data/* above) — script-appended, runtime-only.
.env.vercel
frontend/.env.local
.clerk-test-creds
frontend/test-results/
/scorecard/

# Tier-2 caddie eval run reports (specs/caddie-advice-eval-plan.md) — local only
backend/tests/eval/last_run.json
