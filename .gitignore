# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore all variants, keep examples
.env
.env.*
!.env.example
!.env.*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.Python
*.egg-info/
dist/

# Backend data (local storage — runtime caches, never checked in). Ignore
# contents, not the directory itself, so specific checked-in files below can
# be re-included (git can't un-ignore a file whose parent dir is excluded).
backend/data/*
# Exception: checked-in config data (specs/teetime-s0-plan.md) — the private-
# club exclusion list is source, not a runtime cache; loader fails loudly if
# it's missing, so it must ship with the repo.
!backend/data/private_clubs.json
.env.vercel
frontend/.env.local
.clerk-test-creds
frontend/test-results/
/scorecard/

# Tier-2 caddie eval run reports (specs/caddie-advice-eval-plan.md) — local only
backend/tests/eval/last_run.json
